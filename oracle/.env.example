# RPC URL for Sepolia testnet
RPC_URL=https://sepolia.gateway.tenderly.co

# Private key of the oracle operator (DO NOT COMMIT THIS)
PRIVATE_KEY=your_private_key_here

# BlindOracleAnalyst contract address
CONTRACT_ADDRESS=0xC2b2677E092191f96373CA54920fAc16863F92Ed
VAULT_ADDRESS=0xEBe26e87b898152e387C4f18F4C8DA932cbDC29f
TOKEN_ADDRESS=0x0a9A09B392f95D8999a1a5a14E09cd378Fc23F78

# HTTP API used by the frontend for live analysis
ORACLE_PORT=8787

# Optional. If omitted, the oracle uses simulated demo responses.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Demo yield feed. 520 bps = 5.20% APY.
# Replace this source with a live oracle/API feed before production.
YIELD_APY_BPS=520
YIELD_SOURCE=configured-demo-rate
RWA_USD_PRICE=1

# Live price feed (Ondo Finance for RWA demo)
PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=ondo-finance&vs_currencies=usd
PRICE_CACHE_TTL_MS=60000

# Optional external APY endpoint. Should return JSON with an apy or apyPercent field.
# APY_SOURCE_URL=https://your-apy-api.example/rate
